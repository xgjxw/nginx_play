  /**
   * 海报模板渲染引擎
   */

  class PosterEngine {
    constructor(template, data) {
      this.data = JSON.parse(JSON.stringify(data));

      if (!this.data.coverImage) {
        this.data.coverImage = DefaultCovers.getRandom();
      }

      this.template = JSON.parse(JSON.stringify(template));
      const replaceData = this.data;

      const replaceVars = (obj) => {
        if (typeof obj === 'string') {
          return obj.replace(/\{\{([a-zA-Z0-9_]+)\}\}/g, (match, key) => {
            return (replaceData[key] !== undefined && replaceData[key] !== null) ? replaceData[key] : ''
          })
        }
        if (Array.isArray(obj)) return obj.map(replaceVars)
        if (obj && typeof obj === 'object') {
          const result = {};
          for (const key in obj) result[key] = replaceVars(obj[key]);
          return result
        }
        return obj
      };

      this.template = replaceVars(this.template);
      this.template.elements = this.template.elements.filter(el => {
        if (el.type === 'image' && !el.url) return false
        if (el.type === 'text' && !el.text) return false
        return true
      });

      const hasIcon = this.template.elements.some(el => el.type === 'image' && el.y < 150);
      if (!hasIcon) {
        this.template.elements.forEach(el => {
          if (el.type === 'text' && el.y < 150 && el.x > 60) el.x = 40;
        });
      }
    }

    async render() {
      const { width, padding = [0,0,0,0], backgroundColor, elements } = this.template;
      const canvas = document.createElement('canvas');
      const dpr = window.devicePixelRatio || 1;

      const imagesMap = await this._preloadImages(elements);
      const hasHeader = elements.some(el => el.position === 'absolute' && el.y && el.y < 150 && ((el.type === 'image' && el.url) || (el.type === 'text' && el.text)));

      const measureCtx = canvas.getContext('2d');
      let currentY = padding[0];
      let hasContent = false;
      let isFirstFlowElement = true;

      elements.forEach(el => {
        if (el.position === 'flow') {
          if (isFirstFlowElement) {
            if (!hasHeader && el.marginTop > 100) el.marginTop = 100;
            isFirstFlowElement = false;
          }
          el.computedY = currentY + (el.marginTop || 0);
          let elementHeight = el.height || 0;
          if (el.type === 'text') {
            elementHeight = this._measureTextHeight(measureCtx, el);
            if (elementHeight > 0) hasContent = true;
          }
          if (el.type === 'image' && el.url) hasContent = true;
          currentY = el.computedY + elementHeight;
        }
      });

      if (!hasContent) currentY = padding[0] + 300;
      let footerY = currentY + 60;
      let finalHeight = this.template.height === 'auto' ? footerY + 180 + padding[2] : this.template.height;
      const minHeight = width * 1.35;
      const maxHeight = width * 2.2;

      if (finalHeight < minHeight) {
        finalHeight = minHeight;
        if (this.template.height === 'auto') {
          footerY = finalHeight - padding[2] - 180;
        }
      }
      if (finalHeight > maxHeight) {
        finalHeight = maxHeight;
        if (this.template.height === 'auto') {
          footerY = finalHeight - padding[2] - 180;
        }
      }

      canvas.width = width * dpr;
      canvas.height = finalHeight * dpr;
      canvas.style.width = width + 'px';
      canvas.style.height = finalHeight + 'px';

      const ctx = canvas.getContext('2d');
      ctx.scale(dpr, dpr);

      ctx.fillStyle = backgroundColor || '#FFFFFF';
      ctx.fillRect(0, 0, width, finalHeight);

      const cardEl = elements.find(el => el.type === 'rect' && el.height === 'auto');
      if (cardEl) {
        const rectHeight = footerY + 140 - cardEl.y;
        ctx.save();
        if (cardEl.shadow) {
          ctx.shadowColor = cardEl.shadow.color;
          ctx.shadowBlur = cardEl.shadow.blur;
          ctx.shadowOffsetY = cardEl.shadow.offsetY;
          ctx.shadowOffsetX = cardEl.shadow.offsetX || 0;
        }
        this._drawRoundRect(ctx, cardEl.x, cardEl.y, cardEl.width, rectHeight, cardEl.borderRadius);
        ctx.fillStyle = cardEl.fill || '#fff';
        ctx.fill();
        ctx.restore();
      }

      for (const el of elements) {
        if (el.type === 'rect' && el.height === 'auto') continue
        let renderY = el.position === 'flow' ? el.computedY : el.y;
        if (typeof renderY === 'string' && renderY.includes('footerY')) {
          renderY = eval(renderY.replace('footerY', footerY));
        }

        ctx.save();
        if (el.shadow) {
          ctx.shadowColor = el.shadow.color;
          ctx.shadowBlur = el.shadow.blur;
          ctx.shadowOffsetY = el.shadow.offsetY;
          ctx.shadowOffsetX = el.shadow.offsetX || 0;
        }

        switch (el.type) {
          case 'rect':
            this._drawRoundRect(ctx, el.x, renderY, el.width, el.height, el.borderRadius);
            ctx.fillStyle = el.fill || '#fff';
            ctx.fill();
            break
          case 'image':
            const img = imagesMap[el.url];
            if (img) {
              this._drawRoundRect(ctx, el.x, renderY, el.width, el.height, el.borderRadius || 0);
              ctx.clip();
              ctx.drawImage(img, el.x, renderY, el.width, el.height);
            }
            break
          case 'text':
            this._drawText(ctx, el, el.x, renderY);
            break
        }
        ctx.restore();
      }

      return canvas.toDataURL('image/png', 0.9)
    }

    async _preloadImages(elements) {
      const map = {};
      const promises = elements.filter(el => el.type === 'image' && el.url).map(el => {
        return new Promise((resolve) => {
          const img = new Image();
          img.crossOrigin = 'Anonymous';
          img.onload = () => { map[el.url] = img; resolve(); };
          img.onerror = () => resolve();
          img.src = el.url;
        })
      });
      await Promise.all(promises);
      return map
    }

    _drawRoundRect(ctx, x, y, w, h, radius) {
      ctx.beginPath();
      if (!radius) {
        ctx.rect(x, y, w, h);
        return
      }
      const r = Array.isArray(radius) ? radius : [radius, radius, radius, radius];
      ctx.moveTo(x + r[0], y);
      ctx.lineTo(x + w - r[1], y);
      ctx.arc(x + w - r[1], y + r[1], r[1], 1.5 * Math.PI, 2 * Math.PI);
      ctx.lineTo(x + w, y + h - r[2]);
      ctx.arc(x + w - r[2], y + h - r[2], r[2], 0, 0.5 * Math.PI);
      ctx.lineTo(x + r[3], y + h);
      ctx.arc(x + r[3], y + h - r[3], r[3], 0.5 * Math.PI, Math.PI);
      ctx.lineTo(x, y + r[0]);
      ctx.arc(x + r[0], y + r[0], r[0], Math.PI, 1.5 * Math.PI);
      ctx.closePath();
    }

    _measureTextHeight(ctx, el) {
      if (!el.text || !el.text.trim() || !el.width) return 0
      ctx.font = `${el.fontWeight || 'normal'} ${el.fontSize}px sans-serif`;
      const words = el.text.split('');
      let line = '', lines = 1;
      for (let i = 0; i < words.length; i++) {
        const testLine = line + words[i];
        if (ctx.measureText(testLine).width > el.width && i > 0) {
          lines++;
          line = words[i];
          if (el.maxLines && lines > el.maxLines) {
            lines = el.maxLines;
            break
          }
        } else {
          line = testLine;
        }
      }
      return lines * (el.lineHeight || el.fontSize * 1.5)
    }

    _drawText(ctx, el, x, y) {
      if (!el.text || !el.text.trim()) return
      ctx.font = `${el.fontWeight || 'normal'} ${el.fontSize}px sans-serif`;
      ctx.fillStyle = el.color || '#000';
      ctx.textBaseline = 'top';
      const words = el.text.split('');
      let line = '', currentY = y, lineCount = 1;
      for (let i = 0; i < words.length; i++) {
        const testLine = line + words[i];
        if (ctx.measureText(testLine).width > el.width && i > 0) {
          if (el.maxLines && lineCount >= el.maxLines) {
            let truncLine = line;
            while (truncLine.length > 0 && ctx.measureText(truncLine + '...').width > el.width) {
              truncLine = truncLine.slice(0, -1);
            }
            ctx.fillText(truncLine + '...', x, currentY);
            return
          }
          ctx.fillText(line, x, currentY);
          line = words[i];
          currentY += el.lineHeight || el.fontSize * 1.5;
          lineCount++;
        } else {
          line = testLine;
        }
      }
      if (line) ctx.fillText(line, x, currentY);
    }
  }

  /**
   * 二维码生成器
   * 使用 qrcodejs 库（通过动态加载）
   */

  let qrcodeLib = null;

  // 动态加载 qrcode 库
  async function loadQRCodeLib() {
    if (qrcodeLib) return qrcodeLib

    return new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js';
      script.onload = () => {
        qrcodeLib = window.QRCode;
        resolve(qrcodeLib);
      };
      script.onerror = reject;
      document.head.appendChild(script);
    })
  }

  /**
   * 生成二维码
   */
  async function generateQRCode(text, size = 120) {
    try {
      await loadQRCodeLib();

      const container = document.createElement('div');
      container.style.display = 'none';
      document.body.appendChild(container);

      const qrcode = new window.QRCode(container, {
        text: text,
        width: size,
        height: size,
        colorDark: '#000000',
        colorLight: '#ffffff',
        correctLevel: window.QRCode.CorrectLevel.M
      });

      // 等待生成完成
      await new Promise(resolve => setTimeout(resolve, 100));

      const canvas = container.querySelector('canvas');
      const dataUrl = canvas.toDataURL('image/png');

      document.body.removeChild(container);

      return dataUrl
    } catch (error) {
      console.error('QR Code generation failed:', error);
      // 降级方案：使用第三方 API
      return `https://api.qrserver.com/v1/create-qr-code/?size=${size}x${size}&data=${encodeURIComponent(text)}`
    }
  }

