  /**
   * App Insight Frontend SDK
   * Version: 2.1.0
   */


  // ============ 主SDK类 ============

  class AppInsightSDK {
    constructor() {
      this.config = {
        appCode: '',
        publicToken: '',
        apiEndpoint: 'https://insightapp.memect.cn',
        autoTrackPageView: false,
        batchSize: 10,
        batchInterval: 5000,
        debug: false
      };
      this.queue = [];
      this.timer = null;
      this.userId = null;
      this.userProperties = {};
      this.deviceId = this._getOrCreateDeviceId();
      this.sessionId = this._generateSessionId();
      this.pageEnterTime = Date.now();
      this.isPageVisible = true;
      this.totalVisibleTime = 0;
      this.lastVisibilityChange = Date.now();
      this.initialized = false;
    }

    /**
     * 初始化SDK
     */
    init(config) {
      if (this.initialized) {
        console.warn('[AppInsight] SDK already initialized');
        return
      }

      this.config = { ...this.config, ...config };

      if (this.config.debug) {
        console.log('[AppInsight] SDK initialized', this.config);
      }

      this.initialized = true;

      // 启动批量上报定时器
      this._startBatchTimer();

      // 自动追踪页面访问
      if (this.config.autoTrackPageView) {
        this.trackPageView();

        // 监听路由变化（SPA）
        if (typeof window !== 'undefined') {
          window.addEventListener('popstate', () => this.trackPageView());
          this._monitorHistoryChanges();
        }
      }

      // 页面卸载时上报剩余数据
      if (typeof window !== 'undefined') {
        window.addEventListener('beforeunload', () => {
          this._flush();
        });
      }

      // 自动采集首屏加载时间
      this._trackPageLoadPerformance();

      // 自动追踪页面可见性（使用时长）
      this._trackPageVisibility();
    }

    /**
     * 追踪页面访问
     */
    trackPageView(params = {}) {
      const data = {
        event_type: 'page_view',
        page: params.page || window.location.pathname,
        title: params.title || document.title,
        referrer: params.referrer || document.referrer,
        url: window.location.href,
        timestamp: new Date().toISOString(),
        ...this._getCommonData()
      };

      this._addToQueue(data);
    }

    /**
     * 追踪事件
     */
    trackEvent(eventName, properties = {}) {
      const data = {
        event_type: 'custom_event',
        event_name: eventName,
        properties: properties,
        timestamp: new Date().toISOString(),
        ...this._getCommonData()
      };

      this._addToQueue(data);
    }

    /**
     * 追踪错误
     */
    trackError(error, context = {}) {
      const data = {
        event_type: 'error',
        error_message: error.message || String(error),
        error_stack: error.stack || '',
        error_type: error.name || 'Error',
        context: context,
        page: window.location.pathname,
        timestamp: new Date().toISOString(),
        ...this._getCommonData()
      };

      this._addToQueue(data);
    }

    /**
     * 启用全局错误监控
     */
    enableErrorTracking() {
      if (typeof window === 'undefined') return

      window.addEventListener('error', (event) => {
        this.trackError(event.error || new Error(event.message), {
          filename: event.filename,
          lineno: event.lineno,
          colno: event.colno
        });
      });

      window.addEventListener('unhandledrejection', (event) => {
        this.trackError(new Error(event.reason), {
          type: 'unhandled_promise_rejection'
        });
      });
    }

    /**
     * 追踪性能指标
     */
    trackPerformance(metric) {
      const data = {
        event_type: 'performance',
        metric_name: metric.metric,
        metric_value: metric.value,
        page: metric.page || window.location.pathname,
        timestamp: new Date().toISOString(),
        ...this._getCommonData()
      };

      this._addToQueue(data);
    }

    /**
     * 设置用户ID
     */
    setUserId(userId) {
      this.userId = userId;
    }

    /**
     * 设置用户属性
     */
    setUserProperties(properties) {
      this.userProperties = { ...this.userProperties, ...properties };
    }

    /**
     * 提交反馈
     */
    submitFeedback(content, contact = '', extraContext = {}) {
      const endpoint = `${this.config.apiEndpoint.replace(/\/$/, '')}/api/feedbacks`;

      // 收集丰富的上下文信息
      const context = {
        page_url: window.location.href,
        page_title: document.title,
        page_path: window.location.pathname,
        referrer: document.referrer,
        timestamp: new Date().toISOString(),
        browser: this._parseDeviceInfo().browser,
        os: this._parseDeviceInfo().os,
        device_type: this._parseDeviceInfo().deviceType,
        screen: `${window.screen.width}x${window.screen.height}`,
        viewport: `${window.innerWidth}x${window.innerHeight}`,
        language: navigator.language,
        ...extraContext
      };

      return fetch(endpoint, {
        method: 'POST',
        headers: (() => {
          const h = { 'Content-Type': 'application/json' };
          if (this.config.appCode) h['X-App-ID'] = this.config.appCode;
          if (this.config.publicToken) h['X-Public-Token'] = this.config.publicToken;
          return h
        })(),
        body: JSON.stringify({
          content,
          contact,
          meta_data: context
        })
      })
    }

    /**
     * 创建反馈组件
     */
    createFeedbackWidget(options = {}) {
      return createFeedbackWidget(this, options)
    }

    /**
     * 生成二维码（轻量级实现）
     */
    _generateQRCode(text, size = 200) {
      const canvas = document.createElement('canvas');
      canvas.width = size;
      canvas.height = size;
      const ctx = canvas.getContext('2d');

      // 简化版：使用第三方API生成二维码
      // 实际项目中可以用 qrcode.js 或后端生成
      const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=${size}x${size}&data=${encodeURIComponent(text)}`;

      return new Promise((resolve) => {
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.onload = () => {
          ctx.drawImage(img, 0, 0, size, size);
          resolve(canvas);
        };
        img.onerror = () => {
          // 失败时绘制占位符
          ctx.fillStyle = '#f0f0f0';
          ctx.fillRect(0, 0, size, size);
          ctx.fillStyle = '#999';
          ctx.font = '16px sans-serif';
          ctx.textAlign = 'center';
          ctx.fillText('二维码', size / 2, size / 2);
          resolve(canvas);
        };
        img.src = qrUrl;
      })
    }
    /**
     * 使用模板生成海报
     */
    async createPosterByTemplate(options = {}) {
      const {
        template = 'full_bleed',
        title = document.title,
        description = '快来体验吧！',
        appName = '',
        appIcon = '',
        coverImage = '',
        themeColor = '#667eea',
        url = window.location.href
      } = options;

      const qrCode = await generateQRCode(url, 120);

      const templateObj = templates[template] || templates.full_bleed;
      const engine = new PosterEngine(templateObj, {
        title,
        description,
        appName,
        appIcon,
        coverImage,
        themeColor,
        qrCode
      });

      return await engine.render()
    }

    /**
     * 默认海报模板
     */
    async _renderDefaultTemplate({ width, height, title, description, url }) {
      const canvas = document.createElement('canvas');
      canvas.width = width;
      canvas.height = height;
      const ctx = canvas.getContext('2d');

      // 渐变背景
      const gradient = ctx.createLinearGradient(0, 0, 0, height);
      gradient.addColorStop(0, '#667eea');
      gradient.addColorStop(1, '#764ba2');
      ctx.fillStyle = gradient;
      ctx.fillRect(0, 0, width, height);

      // 白色卡片
      const cardY = 150;
      const cardHeight = height - 300;
      ctx.fillStyle = '#ffffff';
      ctx.shadowColor = 'rgba(0,0,0,0.1)';
      ctx.shadowBlur = 30;
      ctx.shadowOffsetY = 10;
      this._roundRect(ctx, 60, cardY, width - 120, cardHeight, 20);
      ctx.fill();
      ctx.shadowColor = 'transparent';

      // 标题
      ctx.fillStyle = '#1a1a1a';
      ctx.font = 'bold 56px sans-serif';
      ctx.textAlign = 'center';
      this._wrapText(ctx, title, width / 2, cardY + 100, width - 200, 70);

      // 描述
      ctx.fillStyle = '#666';
      ctx.font = '36px sans-serif';
      this._wrapText(ctx, description, width / 2, cardY + 220, width - 200, 50);

      // 二维码
      const qrSize = 280;
      const qrCanvas = await this._generateQRCode(url, qrSize);
      const qrX = (width - qrSize) / 2;
      const qrY = cardY + 350;
      ctx.drawImage(qrCanvas, qrX, qrY, qrSize, qrSize);

      // 提示文字
      ctx.fillStyle = '#999';
      ctx.font = '32px sans-serif';
      ctx.fillText('长按识别二维码', width / 2, qrY + qrSize + 60);

      return canvas.toDataURL('image/png')
    }

    /**
     * 创建分享组件
     */
    createShareWidget(options = {}) {
      return createShareWidget(this, options)
    }

    /**
     * 手动上报数据
     */
    flush() {
      this._flush();
      if (this.config.debug) {
        console.log('[AppInsight] Manual flush triggered');
      }
    }

    /**
     * 获取公共数据
     */
    _getCommonData() {
      const deviceInfo = this._parseDeviceInfo();
      return {
        user_id: this.userId,
        device_id: this.deviceId,
        session_id: this.sessionId,
        user_properties: this.userProperties,
        user_agent: navigator.userAgent,
        browser: deviceInfo.browser,
        os: deviceInfo.os,
        device_type: deviceInfo.deviceType,
        screen_resolution: `${window.screen.width}x${window.screen.height}`,
        viewport_size: `${window.innerWidth}x${window.innerHeight}`,
        language: navigator.language
      }
    }

    /**
     * 解析设备信息
     */
    _parseDeviceInfo() {
      const ua = navigator.userAgent;
      let browser = 'Unknown';
      let os = 'Unknown';
      let deviceType = 'Desktop';

      // 解析浏览器
      if (ua.indexOf('Chrome') > -1 && ua.indexOf('Edg') === -1) {
        browser = 'Chrome';
      } else if (ua.indexOf('Safari') > -1 && ua.indexOf('Chrome') === -1) {
        browser = 'Safari';
      } else if (ua.indexOf('Firefox') > -1) {
        browser = 'Firefox';
      } else if (ua.indexOf('Edg') > -1) {
        browser = 'Edge';
      } else if (ua.indexOf('MSIE') > -1 || ua.indexOf('Trident') > -1) {
        browser = 'IE';
      }

      // 解析操作系统
      if (ua.indexOf('Win') > -1) {
        os = 'Windows';
      } else if (ua.indexOf('Mac') > -1) {
        os = 'macOS';
      } else if (ua.indexOf('Linux') > -1) {
        os = 'Linux';
      } else if (ua.indexOf('Android') > -1) {
        os = 'Android';
        deviceType = 'Mobile';
      } else if (ua.indexOf('iOS') > -1 || ua.indexOf('iPhone') > -1 || ua.indexOf('iPad') > -1) {
        os = 'iOS';
        deviceType = ua.indexOf('iPad') > -1 ? 'Tablet' : 'Mobile';
      }

      // 检测移动设备
      if (/Mobile|Android|iPhone/i.test(ua)) {
        deviceType = 'Mobile';
      } else if (/Tablet|iPad/i.test(ua)) {
        deviceType = 'Tablet';
      }

      return { browser, os, deviceType }
    }

    /**
     * 添加到队列
     */
    _addToQueue(data) {
      this.queue.push(data);

      if (this.config.debug) {
        console.log('[AppInsight] Event added to queue:', data);
      }

      // 达到批量大小立即上报
      if (this.queue.length >= this.config.batchSize) {
        this._flush();
      }
    }

    /**
     * 启动批量上报定时器
     */
    _startBatchTimer() {
      if (this.timer) {
        clearInterval(this.timer);
      }

      this.timer = setInterval(() => {
        if (this.queue.length > 0) {
          this._flush();
        }
      }, this.config.batchInterval);
    }

    /**
     * 上报数据
     */
    _flush() {
      if (this.queue.length === 0) return

      const events = [...this.queue];

      // 转换为后端期望的格式
      const metrics = events.map(event => {
        const { event_type, timestamp, ...payload } = event;

        return {
          type: this._mapEventType(event_type),
          payload: payload,
          timestamp: timestamp
        }
      });

      const payload = {
        metrics: metrics
      };

      if (this.config.debug) {
        console.log('[AppInsight] Flushing events:', payload);
      }

      // 智能处理 API 端点
      let endpoint = this.config.apiEndpoint.replace(/\/$/, '');
      if (endpoint.endsWith('/api')) {
        endpoint = `${endpoint}/metrics/track`;
      } else {
        endpoint = `${endpoint}/api/metrics/track`;
      }

      const data = JSON.stringify(payload);

      const headers = { 'Content-Type': 'application/json' };
      if (this.config.appCode) headers['X-App-ID'] = this.config.appCode;
      if (this.config.publicToken) headers['X-Public-Token'] = this.config.publicToken;

      // 使用 fetch
      fetch(endpoint, {
        method: 'POST',
        headers,
        body: data,
        keepalive: true
      }).then(response => {
        if (response.ok) {
          // 发送成功，清空队列
          this.queue = this.queue.slice(events.length);
        } else {
          if (this.config.debug) {
            console.error('[AppInsight] Failed to send events, will retry later');
          }
        }
      }).catch(err => {
        if (this.config.debug) {
          console.error('[AppInsight] Failed to send events:', err);
        }
      });
    }

    /**
     * 映射事件类型
     */
    _mapEventType(eventType) {
      const typeMap = {
        'page_view': 'PAGE_VIEW',
        'custom_event': 'EVENT',
        'error': 'ERROR',
        'performance': 'PERFORMANCE'
      };
      return typeMap[eventType] || 'EVENT'
    }

    /**
     * 生成会话ID
     */
    _generateSessionId() {
      return `session_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`
    }

    /**
     * 监听History API变化
     */
    _monitorHistoryChanges() {
      const originalPushState = history.pushState;
      const originalReplaceState = history.replaceState;

      history.pushState = (...args) => {
        originalPushState.apply(history, args);
        this.trackPageView();
      };

      history.replaceState = (...args) => {
        originalReplaceState.apply(history, args);
        this.trackPageView();
      };
    }

    /**
     * 追踪页面加载性能
     */
    _trackPageLoadPerformance() {
      if (typeof window === 'undefined' || !window.performance || !window.performance.timing) {
        return
      }

      window.addEventListener('load', () => {
        setTimeout(() => {
          const timing = window.performance.timing;
          const loadTime = timing.loadEventEnd - timing.navigationStart;
          const domReady = timing.domContentLoadedEventEnd - timing.navigationStart;
          const firstPaint = timing.responseEnd - timing.fetchStart;

          this.trackPerformance({
            metric: 'page_load_time',
            value: loadTime,
            page: window.location.pathname
          });

          this.trackPerformance({
            metric: 'dom_ready_time',
            value: domReady,
            page: window.location.pathname
          });

          this.trackPerformance({
            metric: 'first_paint_time',
            value: firstPaint,
            page: window.location.pathname
          });

          if (this.config.debug) {
            console.log('[AppInsight] Page load performance tracked:', {
              loadTime,
              domReady,
              firstPaint
            });
          }
        }, 0);
      });
    }

    /**
     * 追踪页面可见性
     */
    _trackPageVisibility() {
      if (typeof document === 'undefined' || typeof document.hidden === 'undefined') {
        return
      }

      document.addEventListener('visibilitychange', () => {
        const now = Date.now();

        if (document.hidden) {
          if (this.isPageVisible) {
            this.totalVisibleTime += now - this.lastVisibilityChange;
            this.isPageVisible = false;

            if (this.config.debug) {
              console.log('[AppInsight] Page hidden, visible time:', this.totalVisibleTime);
            }
          }
        } else {
          this.isPageVisible = true;
          this.lastVisibilityChange = now;

          if (this.config.debug) {
            console.log('[AppInsight] Page visible');
          }
        }
      });

      window.addEventListener('beforeunload', () => {
        const now = Date.now();

        if (this.isPageVisible) {
          this.totalVisibleTime += now - this.lastVisibilityChange;
        }

        this.trackEvent('page_duration', {
          page: window.location.pathname,
          total_time: now - this.pageEnterTime,
          visible_time: this.totalVisibleTime,
          hidden_time: (now - this.pageEnterTime) - this.totalVisibleTime
        });

        if (this.config.debug) {
          console.log('[AppInsight] Page duration tracked:', {
            totalTime: now - this.pageEnterTime,
            visibleTime: this.totalVisibleTime
          });
        }
      });
    }

    /**
     * 获取或创建设备ID
     */
    _getOrCreateDeviceId() {
      const storageKey = '_ai_device_id';

      try {
        const existingId = localStorage.getItem(storageKey);
        if (existingId) {
          return existingId
        }
      } catch (e) {
        // localStorage 不可用
      }

      const deviceId = this._generateDeviceFingerprint();

      try {
        localStorage.setItem(storageKey, deviceId);
      } catch (e) {
        // 忽略存储失败
      }

      return deviceId
    }

    /**
     * 生成设备指纹
     */
    _generateDeviceFingerprint() {
      const components = [];

      components.push(navigator.userAgent);
      components.push(navigator.language);
      components.push(`${window.screen.width}x${window.screen.height}x${window.screen.colorDepth}`);
      components.push(new Date().getTimezoneOffset());
      components.push(navigator.platform);

      if (navigator.hardwareConcurrency) {
        components.push(navigator.hardwareConcurrency);
      }

      components.push(navigator.maxTouchPoints || 0);

      try {
        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');
        if (ctx) {
          ctx.textBaseline = 'top';
          ctx.font = '14px Arial';
          ctx.fillStyle = '#f60';
          ctx.fillRect(0, 0, 100, 50);
          ctx.fillStyle = '#069';
          ctx.fillText('AppInsight', 2, 2);
          components.push(canvas.toDataURL());
        }
      } catch (e) {
        components.push('canvas-error');
      }

      try {
        const canvas = document.createElement('canvas');
        const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
        if (gl) {
          const debugInfo = gl.getExtension('WEBGL_debug_renderer_info');
          if (debugInfo) {
            components.push(gl.getParameter(debugInfo.UNMASKED_VENDOR_WEBGL));
            components.push(gl.getParameter(debugInfo.UNMASKED_RENDERER_WEBGL));
          }
        }
      } catch (e) {
        components.push('webgl-error');
      }

      if (navigator.plugins && navigator.plugins.length > 0) {
        const plugins = Array.from(navigator.plugins)
          .map(p => p.name)
          .sort()
          .join(',');
        components.push(plugins);
      }

      const fingerprint = components.join('|');
      return this._simpleHash(fingerprint)
    }

    /**
     * 简单哈希函数
     */
    _simpleHash(str) {
      let hash = 0;
      for (let i = 0; i < str.length; i++) {
        const char = str.charCodeAt(i);
        hash = ((hash << 5) - hash) + char;
        hash = hash & hash;
      }

      const positiveHash = Math.abs(hash).toString(36);
      const randomPart = Math.random().toString(36).substr(2, 5);
      return `device_${positiveHash}_${randomPart}`
    }
  }

  // 创建单例实例
  const appInsight = new AppInsightSDK();

  return appInsight;

})();
