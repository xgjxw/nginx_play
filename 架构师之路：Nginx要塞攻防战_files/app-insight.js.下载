      const targetEl = typeof container === 'string' ? document.querySelector(container) : container;
      if (targetEl) targetEl.appendChild(wrapper);
    } else {
      document.body.appendChild(wrapper);
    }

    const btn = wrapper.querySelector('.ai-feedback-btn');
    const modal = wrapper.querySelector('.ai-feedback-modal');
    const textarea = wrapper.querySelector('textarea');
    const input = wrapper.querySelector('input');
    const submitBtn = wrapper.querySelector('.ai-feedback-submit');
    const cancelBtn = wrapper.querySelector('.ai-feedback-cancel');
    const closeBtn = wrapper.querySelector('.ai-feedback-close');

    btn.onclick = () => modal.classList.add('show');
    cancelBtn.onclick = () => {
      modal.classList.remove('show');
      textarea.value = '';
      input.value = '';
    };
    closeBtn.onclick = () => cancelBtn.click();
    modal.onclick = (e) => e.target === modal && cancelBtn.click();

    submitBtn.onclick = async () => {
      const content = textarea.value.trim();
      if (!content) return alert('请输入反馈内容')

      submitBtn.disabled = true;
      submitBtn.textContent = '提交中...';

      try {
        await sdk.submitFeedback(content, input.value.trim(), extraContext);
        alert('感谢您的反馈！');
        cancelBtn.click();
        onSuccess();
      } catch (error) {
        alert('提交失败，请稍后重试');
        onError(error);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = '提交';
      }
    };

    return wrapper
  }

