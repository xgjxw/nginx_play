// Wave generation logic
function generateWave(levelDef, waveIndex) {
  var types = levelDef.enemyTypes;
  var difficulty = 1 + waveIndex * 0.25;
  var enemies = [];
  var count = Math.floor(5 + waveIndex * 2);

  // Last wave is always harder
  if (waveIndex === levelDef.waves - 1) {
    difficulty *= 1.5;
    count = Math.floor(count * 1.5);
  }

  for (var i = 0; i < count; i++) {
    var typeId = types[i % types.length];
    var base = ENEMY_TYPES[typeId];
    if (!base) continue;
    enemies.push({
      typeId: typeId,
      hp: Math.floor(base.hp * difficulty),
      maxHp: Math.floor(base.hp * difficulty),
      speed: base.speed,
      dmg: Math.floor(base.dmg * difficulty),
      reward: base.reward,
      spawnDelay: i * 800 + Math.random() * 300
    });
  }
  return enemies;
}

// Get wave preview summary
function getWavePreview(levelDef, waveIndex) {
  var types = levelDef.enemyTypes;
  var counts = {};
  var count = Math.floor(5 + waveIndex * 2);
  if (waveIndex === levelDef.waves - 1) count = Math.floor(count * 1.5);
  for (var i = 0; i < count; i++) {
    var t = types[i % types.length];
    counts[t] = (counts[t] || 0) + 1;
  }
  return Object.keys(counts).map(function(k) {
    return { typeId: k, count: counts[k], enemy: ENEMY_TYPES[k] };
  });
}
