// ===== DRAG & DROP DEPLOY =====
function initDragDrop() {
  var canvas = G.canvas;
  canvas.addEventListener('dragover', function(ev) {
    ev.preventDefault();
    ev.dataTransfer.dropEffect = 'copy';
    // Highlight cell
    var rect = canvas.getBoundingClientRect();
    var cell = getCellAt(ev.clientX - rect.left, ev.clientY - rect.top);
    render();
    if (cell && !cell.occupied) {
      G.ctx.strokeStyle = 'rgba(59,130,246,0.8)';
      G.ctx.lineWidth = 2;
      G.ctx.strokeRect(cell.x+2, cell.y+2, cell.w-4, cell.h-4);
      G.ctx.fillStyle = 'rgba(59,130,246,0.15)';
      G.ctx.fillRect(cell.x+2, cell.y+2, cell.w-4, cell.h-4);
    }
  });

  canvas.addEventListener('drop', function(ev) {
    ev.preventDefault();
    if (!G.draggingType) return;
    var rect = canvas.getBoundingClientRect();
    var cell = getCellAt(ev.clientX - rect.left, ev.clientY - rect.top);
    if (!cell || cell.occupied) { showToast('无法在此处部署', 'error'); return; }
    var type = SKILLS_DATA.serverTypes.find(function(t){ return t.id === G.draggingType; });
    if (!type || G.cores < type.cost) { showToast('核心资源不足', 'error'); return; }
    G.cores -= type.cost;
    var server = createServer(G.draggingType, cell);
    if (!server) return;
    cell.occupied = true; cell.serverId = server.id;
    G.servers.push(server);
    updateHUD();
    updateServerList();
    spawnParticles(server.x, server.y, type.color, 10);
    showFloatingText(server.x, server.y, type.name);
    AppInsight.trackEvent('server_deploy', { type: G.draggingType });
    G.draggingType = null;
  });

  // Click to deploy or select server
  canvas.addEventListener('click', function(ev) {
    var rect = canvas.getBoundingClientRect();
    var mx = ev.clientX - rect.left, my = ev.clientY - rect.top;
    
    // If we have a server type selected for deployment
    if (G.draggingType && G.state === 'prep') {
      var cell = getCellAt(mx, my);
      if (!cell || cell.occupied) {
        showToast('无法在此处部署，请选择空格子', 'error');
        return;
      }
      var type = SKILLS_DATA.serverTypes.find(function(t){ return t.id === G.draggingType; });
      if (!type || G.cores < type.cost) {
        showToast('核心资源不足', 'error');
        return;
      }
      G.cores -= type.cost;
      var server = createServer(G.draggingType, cell);
      if (!server) return;
      cell.occupied = true; cell.serverId = server.id;
      G.servers.push(server);
      updateHUD();
      updateServerList();
      spawnParticles(server.x, server.y, type.color, 10);
      showFloatingText(server.x, server.y, type.name);
      AppInsight.trackEvent('server_deploy', { type: G.draggingType });
      G.draggingType = null;
      render();
      return;
    }
    
    // Otherwise, check if clicking on an existing server
    var hit = G.servers.find(function(s){ return Math.hypot(s.x-mx, s.y-my) < 22; });
    if (hit) {
      G.selectedServer = hit;
      openConfigPanel(hit);
    } else {
      G.selectedServer = null;
      hideConfigPanel();
      document.getElementById('btn-sell-server').style.display = 'none';
    }
    render();
  });

  canvas.addEventListener('contextmenu', function(ev) {
    ev.preventDefault();
    G.selectedServer = null;
    hideConfigPanel();
    document.getElementById('btn-sell-server').style.display = 'none';
  });
}

function showFloatingText(x, y, text) {
  var el = document.createElement('div');
  el.className = 'damage-number';
  el.style.color = '#3b82f6';
  el.style.fontSize = '0.75rem';
  el.textContent = text;
  el.style.left = (x - 30) + 'px';
  el.style.top = (y - 30) + 'px';
  document.getElementById('screen-game').appendChild(el);
  setTimeout(function(){ if (el.parentNode) el.parentNode.removeChild(el); }, 1200);
}

// ===== CONFIG PANEL =====
function openConfigPanel(server) {
  showConfigPanel();
  document.getElementById('config-title').textContent = server.icon + ' ' + server.name;
  document.getElementById('btn-sell-server').style.display = 'block';

  // Stats
  var statsEl = document.getElementById('config-stats');
  statsEl.innerHTML =
    '<div class="config-stat"><div class="config-stat-label">HP</div><div class="config-stat-val">' + server.hp + '/' + server.maxHp + '</div></div>' +
    '<div class="config-stat"><div class="config-stat-label">攻击</div><div class="config-stat-val">' + server.atk + '</div></div>' +
    '<div class="config-stat"><div class="config-stat-label">射程</div><div class="config-stat-val">' + server.range + '</div></div>' +
    '<div class="config-stat"><div class="config-stat-label">攻速</div><div class="config-stat-val">' + server.atkSpeed.toFixed(1) + '/s</div></div>';

  // Skills
  var skillsEl = document.getElementById('config-skills');
  skillsEl.innerHTML = '';
  var availableSkills = SKILLS_DATA.modules.filter(function(m) {
    return m.chapter <= G.chapter;
  });
  availableSkills.forEach(function(mod) {
    var isActive = server.modules.indexOf(mod.id) >= 0;
    var canAfford = G.bandwidth >= mod.cost;
    var chip = document.createElement('div');
    chip.className = 'skill-chip' + (isActive ? ' active' : '') + (!canAfford && !isActive ? ' locked' : '');
    chip.innerHTML =
      '<div class="skill-chip-name">' + mod.icon + ' ' + mod.name + '</div>' +
      '<div class="skill-chip-desc">' + mod.desc + '</div>' +
      '<div class="skill-chip-cost">' + (isActive ? '✅ 已激活' : '⚡' + mod.cost + ' 带宽') + '</div>';
    if (!isActive) {
      chip.addEventListener('click', function() {
        if (applyModule(server, mod.id)) {
          openConfigPanel(server);
          render();
          AppInsight.trackEvent('skill_apply', { skill: mod.id, server: server.typeId });
        } else {
          showToast('带宽不足', 'error');
        }
      });
    }
    skillsEl.appendChild(chip);
  });
}

// ===== SCREEN MANAGEMENT =====
function showScreen(name) {
  document.querySelectorAll('.screen').forEach(function(s){ s.classList.remove('active'); });
  var el = document.getElementById('screen-' + name);
  if (el) el.classList.add('active');
  // Circuit transition
  var t = document.createElement('div');
  t.className = 'scene-transition';
  document.body.appendChild(t);
  setTimeout(function(){ if (t.parentNode) t.parentNode.removeChild(t); }, 500);
}

