function updateServerList() {
  var list = document.getElementById('server-list');
  list.innerHTML = '';
  SKILLS_DATA.serverTypes.forEach(function(type) {
    var div = document.createElement('div');
    div.className = 'server-item' + (G.cores < type.cost ? ' disabled' : '');
    div.innerHTML = '<div class="server-icon">' + type.icon + '</div><div class="server-name">' + type.name + '</div><div class="server-cost">💎' + type.cost + '</div>';
    div.draggable = true;
    
    // Drag support
    div.addEventListener('dragstart', function(ev) {
      if (G.cores < type.cost) { ev.preventDefault(); return; }
      G.draggingType = type.id;
      ev.dataTransfer.effectAllowed = 'copy';
      div.classList.add('dragging');
    });
    div.addEventListener('dragend', function() { 
      G.draggingType = null; 
      div.classList.remove('dragging');
    });
    
    // Click to select for deployment
    div.addEventListener('click', function() {
      if (G.cores < type.cost) {
        showToast('核心资源不足！需要 ' + type.cost + ' 核心', 'error');
        return;
      }
      G.draggingType = type.id;
      showToast('已选择 ' + type.name + '，点击网格部署', 'info');
      // Highlight the item
      list.querySelectorAll('.server-item').forEach(function(item) { item.style.borderColor = ''; });
      div.style.borderColor = '#10b981';
    });
    
    list.appendChild(div);
  });
}

function updateWavePreview() {
  var el = document.getElementById('wave-preview');
  if (!G.level) return;
  var preview = getWavePreview(G.level, G.wave);
  el.innerHTML = preview.map(function(p) {
    return '<div class="enemy-preview-chip"><span class="ep-icon">' + (p.enemy ? p.enemy.icon : '?') + '</span><span class="ep-name">' + (p.enemy ? p.enemy.name : p.typeId) + '</span><span class="ep-count">x' + p.count + '</span></div>';
  }).join('');
}

