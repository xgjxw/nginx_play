document.getElementById('btn-sell-server').addEventListener('click', function() {
  if (!G.selectedServer) return;
  var type = SKILLS_DATA.serverTypes.find(function(t){ return t.id === G.selectedServer.typeId; });
  var refund = Math.floor(type.cost * 0.6);
  var ge = G.globalEffects;
  if (ge.sellRefund) refund = type.cost;
  G.cores += refund;
  removeServer(G.selectedServer);
  G.selectedServer = null;
  hideConfigPanel();
  document.getElementById('btn-sell-server').style.display = 'none';
  updateHUD();
  updateServerList();
  render();
  showToast('服务器已出售，回收 ' + refund + ' 核心', 'success');
});

