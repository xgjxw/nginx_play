document.getElementById('btn-next-level').addEventListener('click', function() {
  var nextIdx = G.levelIdx + 1;
  var nextChapter = G.chapter;
  if (nextIdx >= 5) { nextIdx = 0; nextChapter++; }
  if (nextChapter > 4) { showScreen('menu'); return; }
  if (isLevelUnlocked(nextChapter, nextIdx + 1)) {
    startLevel(nextChapter, nextIdx);
  } else {
    showScreen('chapter');
    renderChapterGrid();
  }
});

// ===== SKILL TREE =====
var _skillTab = 'basic';
var SKILL_TABS = [
  { id: 'basic', label: '基础配置' },
  { id: 'performance', label: '性能调优' },
  { id: 'security', label: '安全加固' },
  { id: 'advanced', label: '高可用' }
];

function renderSkillTree() {
  var sp = parseInt(localStorage.getItem('skillPoints') || '0');
  document.getElementById('skill-points-display').textContent = sp;

  var tabsEl = document.getElementById('skill-tree-tabs');
  tabsEl.innerHTML = '';
  SKILL_TABS.forEach(function(tab) {
    var btn = document.createElement('button');
    btn.className = 'skill-tab' + (tab.id === _skillTab ? ' active' : '');
    btn.textContent = tab.label;
    btn.addEventListener('click', function() {
      _skillTab = tab.id;
      renderSkillTree();
    });
    tabsEl.appendChild(btn);
  });

  var grid = document.getElementById('skill-tree-grid');
  grid.innerHTML = '';
  var unlockedTech = JSON.parse(localStorage.getItem('unlockedTech') || '[]');

  // Show global tech for current tab
  var techs = SKILLS_DATA.globalTech.filter(function(t){ return t.category === _skillTab; });
  // Also show skill modules for current tab
  var mods = SKILLS_DATA.modules.filter(function(m){ return m.category === _skillTab; });

  techs.forEach(function(tech) {
    var isUnlocked = unlockedTech.indexOf(tech.id) >= 0;
    var sp2 = parseInt(localStorage.getItem('skillPoints') || '0');
    var canAfford = sp2 >= tech.cost;
    var node = document.createElement('div');
    node.className = 'skill-node' + (isUnlocked ? ' unlocked' : (!canAfford ? ' locked' : ''));
    node.innerHTML =
      '<div class="skill-node-icon">' + tech.icon + '</div>' +
      '<div class="skill-node-name">' + tech.name + '</div>' +
      '<div class="skill-chip-desc" style="font-size:0.65rem;color:var(--c-muted);margin-top:0.2rem">' + tech.desc + '</div>' +
      '<div class="skill-node-cost">' + (isUnlocked ? '' : '🔑' + tech.cost + '点') + '</div>' +
      '<div class="skill-node-status">' + (isUnlocked ? '✅ 已解锁' : '') + '</div>';
    if (!isUnlocked && canAfford) {
      node.addEventListener('click', function() {
        var sp3 = parseInt(localStorage.getItem('skillPoints') || '0');
        if (sp3 < tech.cost) { showToast('技能点不足', 'error'); return; }
        sp3 -= tech.cost;
        localStorage.setItem('skillPoints', sp3);
        unlockedTech.push(tech.id);
        localStorage.setItem('unlockedTech', JSON.stringify(unlockedTech));
        showToast('解锁：' + tech.name, 'success');
        AppInsight.trackEvent('tech_unlock', { tech: tech.id });
        renderSkillTree();
      });
    }
    grid.appendChild(node);
  });

  mods.forEach(function(mod) {
    var node = document.createElement('div');
    node.className = 'skill-node unlocked';
    node.style.opacity = '0.7';
    node.innerHTML =
      '<div class="skill-node-icon">' + mod.icon + '</div>' +
      '<div class="skill-node-name">' + mod.name + '</div>' +
      '<div class="skill-chip-desc" style="font-size:0.65rem;color:var(--c-muted);margin-top:0.2rem">' + mod.desc + '</div>' +
      '<div class="skill-node-status" style="color:var(--c-blue)">📖 关卡内使用</div>';
    grid.appendChild(node);
  });
}

// ===== LEADERBOARD =====
function loadLeaderboard() {
  var list = document.getElementById('lb-list');
  list.innerHTML = '<div class="lb-loading">加载中...</div>';
  var savedName = localStorage.getItem('playerName') || '';
  document.getElementById('player-name-input').value = savedName;

  // Try API first, fallback to local storage
  _api.getLeaderboard('nginx-fortress', { page_size: 20 }).then(function(data) {
    AppInsight.trackEvent('request_success', { action: 'leaderboard' });
    renderLeaderboardList(data.results || []);
  }).catch(function(e) {
    console.log('Using local leaderboard:', e.message);
    // Fallback to local storage
    var localScores = JSON.parse(localStorage.getItem('localLeaderboard') || '[]');
    renderLeaderboardList(localScores);
  });
}

function renderLeaderboardList(results) {
  var list = document.getElementById('lb-list');
  list.innerHTML = '';
  if (!results || results.length === 0) {
    list.innerHTML = '<div class="lb-loading">暂无记录，快来成为第一名！</div>';
    return;
  }
  results.forEach(function(entry, idx) {
    var row = document.createElement('div');
    var rank = entry.rank || (idx + 1);
    var rankClass = rank === 1 ? ' top1' : rank === 2 ? ' top2' : rank === 3 ? ' top3' : '';
    row.className = 'lb-row';
    row.innerHTML =
      '<div class="lb-rank' + rankClass + '">' + (rank <= 3 ? ['🥇','🥈','🥉'][rank-1] : '#'+rank) + '</div>' +
      '<div class="lb-name">' + (entry.player_name || '匿名架构师') + '</div>' +
      '<div class="lb-score">' + entry.score + '</div>';
    list.appendChild(row);
  });
}

