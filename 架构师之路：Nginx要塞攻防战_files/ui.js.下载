async function buildShareCard(context, _unused, helpers) {
  var theme = context.meta.theme;
  var root = helpers.createPosterRoot(context, {
    width: 800, padding: 32, radius: 28,
    styles: {
      background: theme.background,
      color: theme.textColor,
      border: '1px solid ' + theme.borderColor,
      display: 'flex',
      flexDirection: 'column',
      gap: '20px'
    }
  });

  // Header
  var header = helpers.createElement('div');
  helpers.setStyles(header, { display: 'flex', alignItems: 'center', gap: '16px', paddingBottom: '16px', borderBottom: '1px solid ' + theme.borderColor });
  var logoIcon = helpers.createElement('div', '', '⬡');
  helpers.setStyles(logoIcon, { fontSize: '2.5rem', color: theme.accentColor });
  var titleBlock = helpers.createElement('div');
  var t1 = helpers.createElement('div', '', '架构师之路：Nginx要塞攻防战');
  helpers.setStyles(t1, { fontSize: '1.2rem', fontWeight: '800', color: theme.textColor });
  var t2 = helpers.createElement('div', '', context.shareSubtitle);
  helpers.setStyles(t2, { fontSize: '0.85rem', color: theme.mutedTextColor, marginTop: '4px' });
  titleBlock.appendChild(t1); titleBlock.appendChild(t2);
  var badge = helpers.createElement('div', '', context.shareBadge);
  helpers.setStyles(badge, { marginLeft: 'auto', background: 'rgba(59,130,246,0.2)', border: '1px solid rgba(59,130,246,0.4)', color: theme.accentColor, padding: '6px 14px', borderRadius: '20px', fontSize: '0.85rem', fontWeight: '700' });
  helpers.appendChildren(header, [logoIcon, titleBlock, badge]);
  root.appendChild(header);

  // Stats from page
  var statsClone = helpers.cloneNodeForShare('[data-share-fragment="stats"]', {
    keepSize: false,
    styles: { width: '100%', maxWidth: '100%', margin: '0', background: 'transparent' }
  });
  if (statsClone) {
    helpers.setStyles(statsClone, { filter: 'none' });
    root.appendChild(statsClone);
  }

  // Summary items
  if (context.summaryItems && context.summaryItems.length) {
    var row = helpers.createElement('div');
    helpers.setStyles(row, { display: 'grid', gridTemplateColumns: 'repeat(3,1fr)', gap: '12px' });
    context.summaryItems.forEach(function(item) {
      var cell = helpers.createElement('div');
      helpers.setStyles(cell, { background: theme.surfaceColor, border: '1px solid ' + theme.borderColor, borderRadius: '12px', padding: '12px', textAlign: 'center' });
      var val = helpers.createElement('div', '', item.value);
      helpers.setStyles(val, { fontSize: '1.4rem', fontWeight: '800', color: item.emphasis ? theme.accentColor : theme.textColor });
      var lbl = helpers.createElement('div', '', item.label);
      helpers.setStyles(lbl, { fontSize: '0.72rem', color: theme.mutedTextColor, marginTop: '4px' });
      cell.appendChild(val); cell.appendChild(lbl);
      row.appendChild(cell);
    });
    root.appendChild(row);
  }

  // QR
  var qrUrl = await helpers.createQRCodeImage(context);
  if (qrUrl) {
    var qrPanel = helpers.createElement('div');
    helpers.setStyles(qrPanel, { display: 'flex', alignItems: 'center', gap: '16px', background: theme.surfaceColor, border: '1px solid ' + theme.borderColor, borderRadius: '16px', padding: '16px' });
    var qrImg = helpers.createElement('img');
    qrImg.src = qrUrl;
    helpers.setStyles(qrImg, { width: '100px', height: '100px', borderRadius: '8px' });
    var qrText = helpers.createElement('div');
    var qt = helpers.createElement('div', '', context.meta.qrTitle);
    helpers.setStyles(qt, { fontSize: '0.9rem', fontWeight: '700', color: theme.textColor });
    var qc = helpers.createElement('div', '', context.meta.qrCaption);
    helpers.setStyles(qc, { fontSize: '0.75rem', color: theme.mutedTextColor, marginTop: '6px' });
    qrText.appendChild(qt); qrText.appendChild(qc);
    helpers.appendChildren(qrPanel, [qrImg, qrText]);
    root.appendChild(qrPanel);
  }

  return root;
}

