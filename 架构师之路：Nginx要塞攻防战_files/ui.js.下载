// ===== CHAPTER GRID =====
function renderChapterGrid() {
  var grid = document.getElementById('chapter-grid');
  grid.innerHTML = '';
  CHAPTERS.forEach(function(ch) {
    var unlocked = ch.id === 1 || isLevelUnlocked(ch.id, 1);
    var card = document.createElement('div');
    card.className = 'chapter-card' + (unlocked ? '' : ' locked');
    card.innerHTML =
      '<div class="chapter-num">第' + ch.id + '章</div>' +
      '<div class="chapter-name">' + ch.icon + ' ' + ch.name + '</div>' +
      '<div class="chapter-desc">' + ch.desc + '</div>' +
      '<span class="chapter-diff diff-' + ch.diff + '">' + ch.diffLabel + '</span>';
    if (unlocked) {
      card.addEventListener('click', function() {
        showScreen('level');
        document.getElementById('level-screen-title').textContent = '第' + ch.id + '章：' + ch.name;
        renderLevelGrid(ch.id);
        AppInsight.trackEvent('chapter_select', { chapter: ch.id });
      });
    }
    grid.appendChild(card);
  });
}

// ===== LEVEL GRID =====
function renderLevelGrid(chapterId) {
  var grid = document.getElementById('level-grid');
  grid.innerHTML = '';
  for (var i = 1; i <= 5; i++) {
    var unlocked = isLevelUnlocked(chapterId, i);
    var stars = getLevelStars(chapterId, i);
    var card = document.createElement('div');
    card.className = 'level-card' + (unlocked ? '' : ' locked');
    var starStr = '';
    for (var s = 1; s <= 3; s++) starStr += s <= stars ? '⭐' : '☆';
    card.innerHTML = '<div class="level-num">' + i + '</div><div class="level-stars">' + starStr + '</div>';
    if (unlocked) {
      (function(ci, li) {
        card.addEventListener('click', function() {
          startLevel(ci, li - 1);
          AppInsight.trackEvent('level_select', { chapter: ci, level: li });
        });
      })(chapterId, i);
    }
    grid.appendChild(card);
  }
}

